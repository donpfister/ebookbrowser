# URL of your Calibre-Web Automated instance (no trailing slash).
# If CWA is on the same machine as this app, use 127.0.0.1 (most reliable —
# avoids DNS entirely). If on a separate machine, use its LAN IP address.
CWA_URL=http://127.0.0.1:8083

# CWA login credentials used to authenticate OPDS requests
CWA_USERNAME=your_username
CWA_PASSWORD=your_password

# Set to false to hide cover thumbnails (faster page loads on Kobo)
SHOW_COVERS=true

# Number of books shown per page (keep low for Kobo — fewer cover images to load)
PAGE_SIZE=20

# Width in pixels to resize cover thumbnails (height scales proportionally).
# Smaller = faster page loads. Increase if covers look too small on your Kobo.
COVER_WIDTH=60

# Port this app listens on
PORT=5000

# Logging verbosity: WARNING (quiet, default), INFO (request summaries), DEBUG (full detail)
LOG_LEVEL=WARNING
