# URL of your Calibre-Web Automated instance (no trailing slash)
CWA_URL=http://192.168.1.100:8083

# CWA login credentials used to authenticate OPDS requests
CWA_USERNAME=your_username
CWA_PASSWORD=your_password

# Set to false to hide cover thumbnails (faster page loads)
SHOW_COVERS=true

# Port this app listens on (change the left side of ports: in docker-compose.yml to match)
PORT=5000
